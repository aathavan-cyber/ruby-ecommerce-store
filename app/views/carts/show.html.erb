<!-- app/views/carts/show.html.erb -->
<div class="cart-container">
  <h2>Your Shopping Cart</h2>

  <% if @cart.cart_items.any? %>
    <div class="cart-card">
      <% @cart.cart_items.each do |item| %>
        <div class="cart-item">
          
          <div class="cart-item-details">
            <img src="<%= item.product.thumbnail %>" alt="<%= item.product.title %>" class="cart-item-image">
            <div class="cart-item-text">
              <h4><%= link_to item.product.title, product_path(item.product) %></h4>
              <p class="unit-price"><%= number_to_currency(item.product.price) %> each</p>
            </div>
          </div>
          
          <div class="cart-item-pricing">
            <p class="quantity">Qty: <%= item.quantity %></p>
            <p class="total-item-price"><%= number_to_currency(item.product.price * item.quantity) %></p>
          </div>

        </div>
      <% end %>

      <div class="cart-summary">
        <div class="grand-total-wrapper">
          <span class="total-label">Grand Total:</span>
          <h2 class="total-amount"><%= number_to_currency(@cart.total_price) %></h2>
        </div>
        <%= link_to "Proceed to Checkout", checkout_path, class: "btn-checkout" %>
      </div>
    </div>

  <% else %>
    <div class="cart-empty-state">
      <p>Your cart is completely empty.</p>
      <%= link_to "Go Shopping", products_path, class: "btn-shop-fallback" %>
    </div>
  <% end %>
</div>